{
  "name": "ondel-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/landing",
    "dev:app": "npm run dev -w apps/app",
    "build": "npm run build -w apps/landing",
    "build:landing": "npm run build -w apps/landing",
    "build:app": "npm run build -w apps/app",
    "lint": "npm run lint -w apps/landing"
  }
}
